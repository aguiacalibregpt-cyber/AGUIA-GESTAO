{
  "productName": "AGUIA GESTAO",
  "identifier": "com.aguiagestao.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "AGUIA GESTAO",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; connect-src 'self'; font-src 'self'; frame-ancestors 'none'"
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": ["icons/icon.png"]
  },
  "allowlist": {
    "all": false,
    "dialog": true,
    "fs": false,
    "shell": false,
    "os": false,
    "path": false
  }
} 
